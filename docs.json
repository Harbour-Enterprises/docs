{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "SuperDoc API",
  "colors": {
    "primary": "#6741D9",
    "light": "#4B9CFF",
    "dark": "#6741D9"
  },
  "favicon": "/favicon.ico",
  "logo": {
    "light": "/logo/light.png",
    "dark": "/logo/dark.png",
    "href": "https://superdoc.dev"
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Getting Started",
            "pages": [
              "index",
              "quickstart",
              "authentication",
              "rate-limits"
            ]
          },
          {
            "group": "Core Concepts",
            "pages": [
              "concepts/conversions",
              "concepts/file-formats",
              "concepts/error-handling"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "api-reference/introduction"
            ]
          },
          {
            "group": "Document Conversion",
            "pages": [
              "api-reference/endpoint/convert-to-pdf",
              "api-reference/endpoint/public-convert"
            ]
          },
          {
            "group": "Health & Status",
            "pages": [
              "api-reference/endpoint/health",
              "api-reference/endpoint/api-info"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "GitHub",
          "href": "https://github.com/Harbour-Enterprises/SuperDoc",
          "icon": "github"
        },
        {
          "anchor": "Discord",
          "href": "https://discord.gg/superdoc",
          "icon": "discord"
        },
        {
          "anchor": "Status",
          "href": "https://status.superdoc.dev",
          "icon": "signal"
        }
      ]
    }
  },
  "openapi": "/api-reference/openapi.json",
  "api": {
    "baseUrl": "https://api.superdoc.dev",
    "auth": {
      "method": "bearer",
      "name": "API Key"
    },
    "playground": {
      "mode": "show"
    }
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:api@superdoc.dev"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Get API Key",
      "href": "https://dashboard.superdoc.dev"
    }
  },
  "footer": {
    "socials": {
      "x": "https://x.com/superdoc",
      "github": "https://github.com/Harbour-Enterprises/SuperDoc",
      "linkedin": "https://linkedin.com/company/harbour-enterprises"
    }
  },
  "feedback": {
    "suggestEdit": true,
    "raiseIssue": true
  },
  "analytics": {
    "ga4": {
      "measurementId": "G-XXXXXXXXXX"
    }
  }
}